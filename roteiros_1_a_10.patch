+{KwWhile}      { return criaSimbolo(sym.KW_WHILE); }
+{KwDo}         { return criaSimbolo(sym.KW_DO); }
+{abrePar}      { return criaSimbolo(sym.ABREPAR); }
+{fechaPar}     { return criaSimbolo(sym.FECHAPAR); }
